@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="auth-card">
            <div class="text-center mb-4">
                <span class="auth-icon"><i class="bi bi-house-door-fill"></i></span>
                <h3 class="mt-3 mb-1">Create your account</h3>
                <p class="text-muted mb-0">Join House Renting to find or list properties</p>
            </div>

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" name="fullName" class="form-control" placeholder="Your full name" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="At least 6 characters" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">I want to join as</label>
                    <select name="role" id="roleSelect" class="form-select">
                        <option value="Tenant">Tenant — I'm looking for a home</option>
                        <option value="Landlord">Landlord — I want to list properties</option>
                    </select>
                </div>

                <!-- Rent payment plan (Tenant only). "Yearly" unlocks each
                     landlord's yearly discount across the whole platform. -->
                <div class="mb-3" id="paymentPlanGroup">
                    <label class="form-label">How do you prefer to pay rent?</label>
                    <div class="plan-options">
                        <label class="plan-option">
                            <input type="radio" name="paymentPlan" value="Monthly" checked />
                            <span class="plan-option-body">
                                <i class="bi bi-calendar-month"></i>
                                <span class="plan-option-title">Monthly</span>
                                <span class="plan-option-desc">Standard price, no discount</span>
                            </span>
                        </label>
                        <label class="plan-option">
                            <input type="radio" name="paymentPlan" value="Yearly" />
                            <span class="plan-option-body">
                                <i class="bi bi-calendar-check"></i>
                                <span class="plan-option-title">Yearly</span>
                                <span class="plan-option-desc">Pay 12 months upfront &amp; get each landlord's discount</span>
                            </span>
                        </label>
                    </div>
                </div>

                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger">@error.ErrorMessage</div>
                }

                <button type="submit" class="btn btn-auth-primary w-100">Create Account</button>
            </form>

            <div class="text-center mt-3">
                <a href="/Account/Login">Already have an account? Log in</a>
            </div>
        </div>
    </div>
</div>

<script>
    // Payment plan only applies to tenants — hide it for landlords
    const roleSelect = document.getElementById('roleSelect');
    const planGroup = document.getElementById('paymentPlanGroup');

    roleSelect.addEventListener('change', () => {
        planGroup.style.display = roleSelect.value === 'Tenant' ? '' : 'none';
    });
</script>
