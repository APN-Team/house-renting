@model IEnumerable<house_renting.Models.House>
@{
    ViewData["Title"] = "Manage Houses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Houses</h2>
    <a href="/Admin" class="btn btn-outline-dark">← Back</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Type</th>
                <th>City</th>
                <th>Price</th>
                <th>Status</th>
                <th>Landlord</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var house in Model)
            {
                <tr>
                    <td>@house.Title</td>
                    <td><span class="badge bg-warning text-dark">@house.HouseType</span></td>
                    <td>@house.City</td>
                    <td>$@house.MonthlyPrice</td>
                    <td>
                        @if (house.Status == "Available")
                        {
                            <span class="badge bg-success">@house.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@house.Status</span>
                        }
                    </td>
                    <td>@house.Landlord?.FullName</td>
                    <td>
                        <form method="post" action="/Admin/DeleteHouse">
                            <input type="hidden" name="id" value="@house.HouseId" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this house?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
