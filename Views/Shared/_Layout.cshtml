<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - House Renting</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="display:flex; flex-direction:column; min-height:100vh;">

    <nav class="navbar navbar-expand-lg sticky-top" style="background-color:#3a6ea8;">
        <div class="container">

            <div class="w-100">
                <!-- Top Row -->
                <div class="d-flex align-items-center justify-content-between py-2">

                    <!-- Logo -->
                    <a class="navbar-brand fw-bold text-white fs-5" asp-controller="Home" asp-action="Index">
                        🏠 House Renting
                    </a>

                   <!-- Search bar - desktop -->
                <div class="d-none d-lg-flex w-50 position-relative" id="searchWrapper">
                    <input class="form-control rounded-pill px-4"
                        type="search"
                        id="searchInput"
                        placeholder="Search houses, condos, villas..."
                        autocomplete="off" />
                    <div id="searchDropdown" class="position-absolute bg-white shadow rounded w-100 d-none"
                        style="top:42px; z-index:9999; max-height:400px; overflow-y:auto;">
                    </div>
                </div>

                    <!-- Right buttons - hidden on mobile -->
                    <div class="d-none d-lg-flex align-items-center gap-2">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <a class="btn btn-outline-light btn-sm rounded-pill"
                               asp-controller="Account" asp-action="Profile">
                                👤 @User.Identity.Name
                            </a>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button class="btn btn-outline-light btn-sm rounded-pill">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-light btn-sm rounded-pill"
                               asp-controller="Account" asp-action="Login">Log in</a>
                            <a class="btn btn-warning btn-sm rounded-pill"
                               asp-controller="Account" asp-action="Register">Sign up</a>
                        }
                    </div>

                    <!-- Hamburger for mobile -->
                    <button class="navbar-toggler d-lg-none border-0" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarNav"
                            aria-controls="navbarNav"
                            aria-expanded="false">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                </div>

                <hr class="my-0 border-light opacity-25" />

                <!-- Bottom Row - desktop links -->
                <div class="d-none d-lg-flex align-items-center py-1">
                    <ul class="navbar-nav gap-3">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="House" asp-action="Index">Houses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                        @if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Rental" asp-action="MyRequests">My Requests</a>
                            </li>
                        }
                        @if (User.Identity!.IsAuthenticated && User.IsInRole("Landlord"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Rental" asp-action="Manage">Manage Requests</a>
                            </li>
                        }
                        @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="Index">Dashboard</a>
                            </li>
                        }
                    </ul>
                </div>

            </div>

            <!-- Mobile collapse menu -->
            <div class="collapse" id="navbarNav">
                <ul class="navbar-nav mt-2">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="House" asp-action="Index">Houses</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Rental" asp-action="MyRequests">My Requests</a>
                        </li>
                    }
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Landlord"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Rental" asp-action="Manage">Manage Requests</a>
                        </li>
                    }
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Admin" asp-action="Index">Dashboard</a>
                        </li>
                    }
                    <hr class="border-light" />
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Profile">👤 Profile</a>
                        </li>
                        <li class="nav-item pb-2">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button class="btn btn-outline-light btn-sm ms-3">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Log in</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Register">Sign up</a>
                        </li>
                    }
                </ul>
            </div>

        </div>
    </nav>

    <main class="py-4 flex-grow-1">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="py-3 text-center" style="background-color:#3a6ea8; color:#d0e4f7;">
        <p class="mb-0">&copy; 2026 House Renting System</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const input = document.getElementById('searchInput');
        const dropdown = document.getElementById('searchDropdown');

        if (input) {
            input.addEventListener('input', async function () {
                const query = this.value.trim();
                if (query.length < 2) {
                    dropdown.classList.add('d-none');
                    dropdown.innerHTML = '';
                    return;
                }

                const res = await fetch(`/api/houses?search=${encodeURIComponent(query)}`);
                const houses = await res.json();

                if (houses.length === 0) {
                    dropdown.innerHTML = '<div class="p-3 text-muted">No results found</div>';
                } else {
                    dropdown.innerHTML = `
                        <div class="p-2 text-muted small fw-bold border-bottom">HOUSES</div>
                        ${houses.map(h => `
                            <a href="/House/Details/${h.houseId}" class="d-flex align-items-center gap-3 p-3 text-decoration-none border-bottom search-item">
                                <img src="${h.imageUrl || '/images/no-image.png'}" 
                                    style="width:60px; height:60px; object-fit:cover; border-radius:8px;" />
                                <div>
                                    <div class="fw-bold text-dark">${h.title}</div>
                                    <div class="text-muted small">${h.address}, ${h.city}</div>
                                    <div class="text-success small">$${h.price} / month</div>
                                </div>
                            </a>
                        `).join('')}
                        <a href="/House?search=${encodeURIComponent(query)}" 
                        class="d-block text-center p-2 text-primary small">
                        View all results for "${query}"
                        </a>
                    `;
                }

                dropdown.classList.remove('d-none');
            });

            document.addEventListener('click', function (e) {
                if (!document.getElementById('searchWrapper').contains(e.target)) {
                    dropdown.classList.add('d-none');
                }
            });
        }
</script>
</body>
</html>
