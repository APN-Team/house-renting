@using Microsoft.AspNetCore.Identity
@using house_renting.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ApplicationUser? currentUser = null;
    if (User.Identity!.IsAuthenticated)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    var paymentPlan = (currentUser != null && User.IsInRole("Tenant"))
        ? currentUser.PreferredPaymentPlan
        : "Monthly";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - House Renting</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body style="display:flex; flex-direction:column; min-height:100vh;">

    <!-- Used by home page & search scripts to show monthly vs yearly prices -->
    <script>
        window.appUser = {
            isAuthenticated: @(User.Identity!.IsAuthenticated ? "true" : "false"),
            paymentPlan: '@paymentPlan'
        };
    </script>

    <header class="site-header sticky-top">
        <div class="container-xl">

            <!-- ── Top row: Logo (left) + Auth buttons (right) ── -->
            <div class="header-top d-flex align-items-center justify-content-between">

                <a class="brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-house-door-fill"></i></span>
                    <span class="brand-text">House Renting</span>
                </a>

                <div class="d-none d-lg-flex align-items-center gap-2">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        @if (User.IsInRole("Tenant"))
                        {
                            <span class="plan-badge" title="Your rent payment plan">
                                <i class="bi bi-credit-card-2-front"></i>
                                @paymentPlan plan
                            </span>
                        }
                        <a class="btn btn-header-ghost d-flex align-items-center gap-2"
                           asp-controller="Account" asp-action="Profile">
                            @if (currentUser != null && !string.IsNullOrEmpty(currentUser.ProfileImage))
                            {
                                <img src="@currentUser.ProfileImage" class="header-avatar" alt="Profile" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle"></i>
                            }
                            <span>@User.Identity!.Name?.Split('@')[0]</span>
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button class="btn btn-header-ghost">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-header-ghost" asp-controller="Account" asp-action="Login">Log in</a>
                        <a class="btn btn-header-cta" asp-controller="Account" asp-action="Register">Sign up</a>
                    }
                </div>

                <!-- Hamburger (mobile) -->
                <button class="navbar-toggler d-lg-none border-0 text-white" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mobileMenu" aria-controls="mobileMenu" aria-expanded="false">
                    <i class="bi bi-list fs-1"></i>
                </button>
            </div>

            <!-- ── Bottom row: role-based nav links UNDER the logo ── -->
            <nav class="header-nav d-none d-lg-flex">
                <a class="header-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">Home</a>

                <a class="header-link @(currentController == "House" ? "active" : "")"
                   asp-controller="House" asp-action="Index">Houses</a>

                <a class="header-link @(currentAction == "Contact" ? "active" : "")"
                   asp-controller="Home" asp-action="Contact">Contact</a>

                @if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
                {
                    <a class="header-link @(currentController == "Rental" && currentAction == "MyRequests" ? "active" : "")"
                       asp-controller="Rental" asp-action="MyRequests">My Requests</a>
                }
                @if (User.Identity!.IsAuthenticated && User.IsInRole("Landlord"))
                {
                    <a class="header-link @(currentController == "Rental" && currentAction == "Manage" ? "active" : "")"
                       asp-controller="Rental" asp-action="Manage">Manage Requests</a>
                }
                @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a class="header-link @(currentController == "Admin" ? "active" : "")"
                       asp-controller="Admin" asp-action="Index">Dashboard</a>
                }
            </nav>

            <!-- ── Mobile collapse menu ── -->
            <div class="collapse d-lg-none" id="mobileMenu">
                <ul class="navbar-nav pb-3">
                    <li><a class="header-link d-block py-2" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="header-link d-block py-2" asp-controller="House" asp-action="Index">Houses</a></li>
                    <li><a class="header-link d-block py-2" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
                    {
                        <li><a class="header-link d-block py-2" asp-controller="Rental" asp-action="MyRequests">My Requests</a></li>
                    }
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Landlord"))
                    {
                        <li><a class="header-link d-block py-2" asp-controller="Rental" asp-action="Manage">Manage Requests</a></li>
                    }
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <li><a class="header-link d-block py-2" asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                    }
                    <li><hr class="border-light" /></li>
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li><a class="header-link d-block py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle me-1"></i> Profile</a></li>
                        <li class="py-2">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button class="btn btn-header-ghost btn-sm">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li><a class="header-link d-block py-2" asp-controller="Account" asp-action="Login">Log in</a></li>
                        <li><a class="header-link d-block py-2" asp-controller="Account" asp-action="Register">Sign up</a></li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <main class="flex-grow-1 @(currentController == "Home" && currentAction == "Index" ? "" : "py-4")">
        @if (currentController == "Home" && currentAction == "Index")
        {
            @RenderBody()
        }
        else
        {
            <div class="container">
                @RenderBody()
            </div>
        }
    </main>

    <!-- ── Footer ── -->
    <footer class="site-footer">
        <div class="container-xl">
            <div class="row gy-4 py-5">
                <div class="col-lg-4 col-md-6">
                    <a class="brand d-inline-flex align-items-center gap-2 mb-3" asp-controller="Home" asp-action="Index">
                        <span class="brand-icon"><i class="bi bi-house-door-fill"></i></span>
                        <span class="brand-text">House Renting</span>
                    </a>
                    <p class="footer-desc">
                        Find your perfect rental home in Cambodia. Browse houses, villas,
                        condos and apartments with a modern experience.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="footer-social"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-telegram"></i></a>
                        <a href="#" class="footer-social"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="footer-title">Quick Links</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="House" asp-action="Index">Houses</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                        @if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
                        {
                            <li><a asp-controller="Rental" asp-action="MyRequests">My Requests</a></li>
                        }
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 col-6">
                    <h6 class="footer-title">Property Types</h6>
                    <ul class="footer-links">
                        <li><a href="/House?type=House">House</a></li>
                        <li><a href="/House?type=Villa">Villa</a></li>
                        <li><a href="/House?type=Condo">Condo</a></li>
                        <li><a href="/House?type=Apartment">Apartment</a></li>
                        <li><a href="/House?type=Studio">Studio</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-title">Contact</h6>
                    <ul class="footer-links">
                        <li><i class="bi bi-geo-alt me-2"></i>Phnom Penh, Cambodia</li>
                        <li><i class="bi bi-envelope me-2"></i>support@houserenting.com</li>
                        <li><i class="bi bi-telephone me-2"></i>+855 12 345 678</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom text-center py-3">
            &copy; 2026 House Renting System. All rights reserved.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-bottom-nav d-lg-none">

        <a asp-controller="Home" asp-action="Index"
           class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")">
            <i class="bi bi-house-heart"></i>
            <span>Home</span>
        </a>

        <a asp-controller="House" asp-action="Index"
           class="@(currentController == "House" ? "active" : "")">
            <i class="bi bi-buildings"></i>
            <span>Houses</span>
        </a>

        <a asp-controller="Home" asp-action="Contact"
           class="@(currentAction == "Contact" ? "active" : "")">
            <i class="bi bi-envelope"></i>
            <span>Contact</span>
        </a>

        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Profile">
                <i class="bi bi-person-circle"></i>
                <span>Profile</span>
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Login</span>
            </a>
        }

    </nav>
</body>

</html>
