@model IEnumerable<house_renting.Models.RentalRequest>
@{
    ViewData["Title"] = "Manage Requests";
}

<h2 class="mb-4">Rental Requests for My Houses</h2>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <p class="text-muted">No requests yet.</p>
    </div>
}

@foreach (var request in Model)
{
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@request.House?.Title</h5>
                @if (request.Status == "Approved")
                {
                    <span class="badge bg-success">Approved</span>
                }
                else if (request.Status == "Rejected")
                {
                    <span class="badge bg-danger">Rejected</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
            </div>
            <hr />
            <p class="mb-1">👤 Tenant: <strong>@request.Tenant?.FullName</strong> (@request.Tenant?.Email)</p>
            <p class="mb-1">📅 From: <strong>@request.StartDate.ToShortDateString()</strong> To: <strong>@request.EndDate.ToShortDateString()</strong></p>
            <p class="mb-1">💬 Message: @request.Message</p>

            @if (request.Status == "Pending")
            {
                <div class="d-flex gap-2 mt-3">
                    <form method="post" action="/Rental/Approve/@request.RequestId">
                        <button type="submit" class="btn btn-success">✅ Approve</button>
                    </form>
                    <form method="post" action="/Rental/Reject/@request.RequestId">
                        <button type="submit" class="btn btn-danger">❌ Reject</button>
                    </form>
                </div>
            }
        </div>
    </div>
}
