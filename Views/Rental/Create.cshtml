@{
    ViewData["Title"] = "Request to Rent";
    var house = ViewBag.House as house_renting.Models.House;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="mb-1">Request to Rent</h3>
                <p class="text-muted mb-4">@house?.Title — <strong class="text-success">$@house?.Price / month</strong></p>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" name="startDate" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" name="endDate" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message to Landlord</label>
                        <textarea name="message" class="form-control" rows="3" placeholder="Introduce yourself..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Send Request</button>
                        <a href="/House" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
