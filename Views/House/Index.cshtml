@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@model IEnumerable<house_renting.Models.House>
@inject UserManager<house_renting.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Available Houses";

    // Tenant's preferred payment plan decides how prices are displayed
    var showYearly = false;
    if (User.Identity!.IsAuthenticated && User.IsInRole("Tenant"))
    {
        var me = await UserManager.GetUserAsync(User);
        showYearly = me?.PreferredPaymentPlan == "Yearly";
    }
    var currentType = ViewBag.CurrentType as string;
    var currentCity = ViewBag.CurrentCity as string;
    var currentSearch = ViewBag.CurrentSearch as string;
    var cities = ViewBag.Cities as List<string> ?? new List<string>();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Available Houses</h2>
    @if (User.IsInRole("Landlord"))
    {
        <a href="/House/Create" class="btn btn-success">+ Add New House</a>
    }
</div>

<!-- Search bar (mobile) -->
<form asp-controller="House" asp-action="Index" method="get" class="d-lg-none mb-3">
    <div class="input-group">
        <input type="search" name="search" class="form-control rounded-pill"
               placeholder="Search houses, condos, villas..." value="@currentSearch" />
        <button type="submit" class="btn btn-primary ms-2 rounded-pill">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(currentSearch))
{
    <div class="alert alert-info py-2 mb-3">
        Showing results for: <strong>"@currentSearch"</strong>
        <a href="/House" class="ms-2 btn btn-sm btn-outline-secondary">Clear</a>
    </div>
}

<!-- Type Filter -->
<div class="mb-3">
    <p class="text-muted mb-1 fw-500">Filter by Type</p>
    <div class="btn-group flex-wrap" role="group">
        <a href="/House?city=@currentCity&search=@currentSearch"
           class="btn @(currentType == null ? "btn-dark" : "btn-outline-dark")">All</a>
        @foreach (var type in new[] { "House", "Villa", "Condo", "Apartment", "Studio" })
        {
            <a href="/House?type=@type&city=@currentCity&search=@currentSearch"
               class="btn @(currentType == type ? "btn-dark" : "btn-outline-dark")">@type</a>
        }
    </div>
</div>

<!-- City Filter -->
@if (cities.Any())
{
    <div class="mb-4">
        <p class="text-muted mb-1">Filter by Location</p>
        <div class="d-flex flex-wrap gap-2">
            <a href="/House?type=@currentType&search=@currentSearch"
               class="btn btn-sm @(currentCity == null ? "btn-primary" : "btn-outline-primary") rounded-pill">
                <img src="https://cdn-icons-png.flaticon.com/128/3416/3416100.png" loading="lazy" alt="Pin " title="Pin "
                     width="20" height="20"> All Locations
            </a>
            @foreach (var city in cities)
            {
                <a href="/House?type=@currentType&city=@city&search=@currentSearch"
                   class="btn btn-sm @(currentCity == city ? "btn-primary" : "btn-outline-primary") rounded-pill">
                    <img src="https://cdn-icons-png.flaticon.com/128/3416/3416100.png" loading="lazy" alt="Pin " title="Pin "
                         width="20" height="20"> @city
                </a>
            }
        </div>
    </div>
}

<!-- Results count -->
<p class="text-muted mb-3">
    Showing <strong>@Model.Count()</strong> house@(Model.Count() != 1 ? "s" : "")
    @if (currentCity != null)
    {
        <span>in <strong>@currentCity</strong></span>
    }
    @if (currentType != null)
    {
        <span>— Type: <strong>@currentType</strong></span>
    }
</p>

<div class="row">
    @foreach (var house in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(house.ImageUrl))
                {
                    <img src="@house.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover; background:#f0f5fb;"
                         alt="@house.Title" />
                }
                else
                {
                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height:200px;">
                        <span>No Image</span>
                    </div>
                }
                <div class="card-body">
                    <span class="badge bg-warning text-dark mb-2">@house.HouseType</span>
                    <h5 class="card-title">@house.Title</h5>
                    <p class="text-muted" style="cursor:pointer;" onclick="window.location.href='/House?city=@house.City'">
                        <img src="https://cdn-icons-png.flaticon.com/128/3416/3416100.png" loading="lazy" alt="Pin "
                             title="Pin " width="20" height="20"> @house.Address, <span
                        class="text-primary">@house.City</span>
                    </p>
                    @if (showYearly && house.AllowYearlyRental)
                    {
                        <p class="fw-bold text-success mb-1">
                            $@house.YearlyPrice.ToString("N0") / year
                            <span class="discount-chip">-@house.YearlyDiscountPercent.ToString("0")%</span>
                        </p>
                        <p class="text-muted small mb-2"><s>$@((house.MonthlyPrice * 12).ToString("N0")) / year</s> — yearly plan discount applied</p>
                    }
                    else
                    {
                        <p class="fw-bold text-success">$@house.MonthlyPrice / month</p>
                    }
                    @if (house.Landlord != null)
                    {
                        <p class="text-muted small mb-2">🏠 Listed by <strong>@house.Landlord.FullName</strong></p>
                    }
                    <p class="text-muted mb-0">
                        <img src="https://cdn-icons-png.flaticon.com/128/494/494970.png" width="20" height="20">
                        @house.Bedrooms Beds

                        &nbsp;|&nbsp;

                        <img src="https://cdn-icons-png.flaticon.com/128/10753/10753257.png" width="20" height="20">
                        @house.Bathrooms Baths

                        &nbsp;|&nbsp;

                        <img src="/images/meter.png" width="20" height="20" alt="Area" />@house.Area m²
                    </p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a href="/House/Details/@house.HouseId" class="btn btn-primary flex-grow-1">View Details</a>
                    @if (User.IsInRole("Landlord") && house.LandlordId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                    {
                        <a href="/House/Edit/@house.HouseId" class="btn btn-warning">Edit</a>
                        <form method="post" action="/House/Delete/@house.HouseId" class="d-inline">
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Delete this house?')">Delete</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <p class="text-muted">No houses found for "<strong>@currentSearch</strong>".</p>
        <a href="/House" class="btn btn-outline-dark">Clear Filters</a>
    </div>
}
