@model house_renting.Models.House
@{
    ViewData["Title"] = @Model.Title;
}

@if (!string.IsNullOrEmpty(Model.ImageUrl) || Model.HouseImages.Any())
{
    var allImages = new List<string>();
    if (!string.IsNullOrEmpty(Model.ImageUrl)) allImages.Add(Model.ImageUrl);
    allImages.AddRange(Model.HouseImages.Select(i => i.ImageUrl));

    <div id="houseCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (int i = 0; i < allImages.Count; i++)
            {
                <button type="button" data-bs-target="#houseCarousel" data-bs-slide-to="@i"
                    class="@(i == 0 ? "active" : "")"></button>
            }
        </div>
        <div class="carousel-inner rounded">
            @for (int i = 0; i < allImages.Count; i++)
            {
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <img src="@allImages[i]" class="d-block w-100" style="height:450px; object-fit:cover;" />
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#houseCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#houseCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    @if (allImages.Count > 1)
    {
        <div class="row g-2 mb-4">
            @for (int i = 0; i < allImages.Count; i++)
            {
                var idx = i;
                <div class="col-3 col-md-2">
                    <img src="@allImages[idx]" class="w-100 rounded" style="height:80px; object-fit:cover; cursor:pointer; opacity:0.8;"
                         onclick="bootstrap.Carousel.getInstance(document.getElementById('houseCarousel')).to(@idx)" />
                </div>
            }
        </div>
    }
}

<div class="row">
    <div class="col-md-8">
        <span class="badge bg-warning text-dark mb-2">@Model.HouseType</span>
        <h2>@Model.Title</h2>
        <p class="text-muted">📍 @Model.Address, @Model.City</p>
        <p>@Model.Description</p>
        <hr />
        <div class="row text-center">
            <div class="col">
                <h5>🛏 @Model.Bedrooms</h5>
                <small class="text-muted">Bedrooms</small>
            </div>
            <div class="col">
                <h5>🚿 @Model.Bathrooms</h5>
                <small class="text-muted">Bathrooms</small>
            </div>
            <div class="col">
                <h5 class="text-success">$@Model.Price</h5>
                <small class="text-muted">Per month</small>
            </div>
            <div class="col">
                <h5>@Model.Status</h5>
                <small class="text-muted">Status</small>
            </div>
        </div>
        <hr />
        <p>🏠 Landlord: <strong>@Model.Landlord?.FullName</strong></p>

        @if (User.IsInRole("Tenant"))
        {
            <a href="/Rental/Create/@Model.HouseId" class="btn btn-success me-2">Request to Rent</a>
            <a href="/Review/Create/@Model.HouseId" class="btn btn-outline-secondary">Leave a Review</a>
        }
    </div>
</div>

<hr />
<h4 class="mt-4">Reviews (@Model.Reviews.Count)</h4>

@if (!Model.Reviews.Any())
{
    <p class="text-muted">No reviews yet.</p>
}

@foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
{
    <div class="card mb-3">
        <div class="card-body">
            <p class="mb-1">
                @for (int i = 0; i < review.Rating; i++) { <span>⭐</span> }
                <span class="text-muted">(@review.Rating/5)</span>
            </p>
            <p class="mb-1">@review.Comment</p>
            <small class="text-muted">@review.CreatedAt.ToShortDateString()</small>
        </div>
    </div>
}

<a href="/House" class="btn btn-outline-dark mt-3">← Back to listings</a>
