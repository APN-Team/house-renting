@{
    ViewData["Title"] = "Contact Us";
}

<div class="row justify-content-center">
    <div class="col-md-7">

        <h2 class="mb-1">Contact Us</h2>
        <p class="text-muted mb-4">Have a question? We'd love to hear from you.</p>

        <div class="row mb-5">
            <div class="col-md-4 mb-3">
                <div class="card text-center p-3 h-100">
                    <h4><img src="https://cdn-icons-png.flaticon.com/128/447/447031.png" loading="lazy" alt="Maps and Flags " title="Maps and Flags " width="40" height="40"></h4>
                    <h6>Address</h6>
                    <p class="text-muted small">Phnom Penh, Cambodia</p>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card text-center p-3 h-100">
                    <h4><img src="https://cdn-icons-png.flaticon.com/128/126/126341.png" loading="lazy" alt="Telephone " title="Telephone " width="40" height="40"></h4>
                    <h6>Phone</h6>
                    <p class="text-muted small">+855 12 345 678</p>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card text-center p-3 h-100">
                    <h4><img src="https://cdn-icons-png.flaticon.com/128/482/482138.png" loading="lazy" alt="Email " title="Email " width="40" height="40"></h4>
                    <h6>Email</h6>
                    <p class="text-muted small">info@houserenting.com</p>
                </div>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body p-4">
                <h5 class="mb-4">Send us a message</h5>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" placeholder="Your name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="your@email.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input type="text" class="form-control" placeholder="How can we help?" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" rows="4" placeholder="Write your message..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send Message</button>
                </form>
            </div>
        </div>

    </div>
</div>
