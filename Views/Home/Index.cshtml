@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">
    <h1>Find Your Perfect Home</h1>
    <p>Browse hundreds of houses available for rent across Cambodia</p>
    <a href="/House" class="btn btn-light btn-lg mt-3 px-4 rounded-pill">Browse Houses</a>
</div>

<div class="row text-center mt-2">
    <div class="col-md-4 mb-3">
        <div class="card p-4 h-100">
            <h3><img src="https://cdn-icons-png.flaticon.com/128/17616/17616585.png" loading="lazy" alt="Lease " title="Lease " width="64" height="64"></h3>
            <h5>Wide Selection</h5>
            <p class="text-muted">Browse houses across multiple cities</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card p-4 h-100">
            <h3><img src="https://cdn-icons-png.flaticon.com/128/8235/8235859.png" loading="lazy" alt="Calendar date " title="Calendar date " width="64" height="64"></h3>
            <h5>Easy Booking</h5>
            <p class="text-muted">Send rental requests in just a few clicks</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card p-4 h-100">
            <h3><img src="https://cdn-icons-png.flaticon.com/128/3331/3331109.png" loading="lazy" alt="Favourite " title="Favourite " width="64" height="64"></h3>
            <h5>Verified Reviews</h5>
            <p class="text-muted">Read honest reviews from real tenants</p>
        </div>
    </div>
</div>
