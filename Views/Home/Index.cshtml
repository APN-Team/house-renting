@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-dark text-white rounded-3 text-center">
    <h1 class="display-4 fw-bold">Find Your Perfect Home</h1>
    <p class="lead">Browse hundreds of houses available for rent across Cambodia</p>
    <a href="/House" class="btn btn-warning btn-lg mt-2">Browse Houses</a>
</div>

<div class="row text-center mt-4">
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <h3>🏠</h3>
            <h5>Wide Selection</h5>
            <p class="text-muted">Browse houses across multiple cities</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <h3>✅</h3>
            <h5>Easy Booking</h5>
            <p class="text-muted">Send rental requests in just a few clicks</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <h3>⭐</h3>
            <h5>Verified Reviews</h5>
            <p class="text-muted">Read honest reviews from real tenants</p>
        </div>
    </div>
</div>
